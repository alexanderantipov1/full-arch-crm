DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fullarchcrm
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_BAA_SIGNED=false
PORT=5000
NODE_ENV=development
SESSION_SECRET=generate-a-long-random-string-here
LOCAL_DEV_AUTH_BYPASS=true

# ── fusion_crm DatabaseAdapter (Fusion Dental's backend) ──────────────────────
# full-arch-crm is the universal SaaS layer; fusion_crm is one clinic's adapter.
# Any other clinic builds their own adapter implementing the DatabaseAdapter interface.
#
# FUSION_CRM_URL: Base URL of the running fusion_crm REST API instance.
#   Set ADAPTER_TYPE=fusion_crm to activate live HTTP calls to this URL.
#   The adapter will throw a descriptive error if this URL is unreachable —
#   it does NOT fall back to mock data (that would hide production failures).
FUSION_CRM_URL=http://localhost:8000

# FUSION_CRM_API_KEY: Bearer token for authenticating to the fusion_crm REST API.
#   Sent as: Authorization: Bearer <FUSION_CRM_API_KEY>
#   Required when ADAPTER_TYPE=fusion_crm. Get this value from your fusion_crm deployment.
FUSION_CRM_API_KEY=your-api-key-here

FUSION_TENANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
FUSION_CRM_TIMEOUT_MS=10000
FUSION_PHI_REASON_PREFIX=full_arch_crm

# ── DatabaseAdapter bootstrap ─────────────────────────────────────────────────
# ADAPTER_TYPE: which adapter to use at startup
#   "mock"       — local PostgreSQL, no network calls (default for dev)
#   "fusion_crm" — calls fusion_crm REST API at FUSION_CRM_URL
#   "western_dental", "clearchoice", etc. — future DSO adapters
ADAPTER_TYPE=mock

# Tenant identity for this deployment
ADAPTER_TENANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
DEFAULT_TENANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
TENANT_SLUG=fusion-dental
TENANT_NAME=Fusion Dental

# REPL_ID is used by auth middleware
REPL_ID=local-dev-fullarch
ISSUER_URL=https://replit.com/oidc

# ── EligibilityAgent — Insurance API integration ──────────────────────────────
# INSURANCE_PROVIDER: which real-time eligibility provider to use.
#   "availity"          — Availity REST API (primary; requires OAuth2 credentials below)
#   "changehealthcare"  — Change Healthcare REST API (fallback)
#   unset / empty       — mock mode (returns realistic synthetic data; logs a warning)
INSURANCE_PROVIDER=availity

# Availity OAuth2 client credentials (required when INSURANCE_PROVIDER=availity)
#   Obtain at: https://developer.availity.com
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=

# Change Healthcare API key (required when INSURANCE_PROVIDER=changehealthcare,
# and always required for prior auth submission via PriorAuthAgent)
#   Obtain at: https://developers.changehealthcare.com
CHANGE_HEALTHCARE_API_KEY=
