"""Unit tests for ``SfLeadIngestService``.

Mock-based per the existing test pattern in this codebase (see
``tests/identity/test_service.py`` and ``tests/ops/test_service.py``).
Real-DB integration follows when a Postgres test container lands.

Coverage focus:
  * Pull flow with each branch of the dedupe ladder (re-pull / email match /
    phone match / brand-new).
  * Idempotency assertions on the dedupe outcomes.
  * Wiring of provider_metadata into ``OpsService.upsert_lead``.
  * SOQL parameter shape (limit clamp, query string).

Every service call passes ``_TENANT_ID`` (ENG-128); the assertions match
the post-sweep call shape.
"""

from __future__ import annotations

import uuid
from datetime import UTC, datetime
from typing import Any
from unittest.mock import AsyncMock, MagicMock

import pytest

from packages.core.types import TenantId
from packages.ingest.sf_lead_service import SfLeadIngestService

_TENANT_ID: TenantId = TenantId(uuid.uuid4())


def _record(
    *,
    sf_id: str = "00Q123",
    first: str | None = "Jane",
    last: str | None = "Doe",
    email: str | None = "jane@example.com",
    phone: str | None = "+15551234567",
    status: str = "Open",
    source: str = "Web",
    company: str | None = "Acme",
) -> dict[str, Any]:
    return {
        "Id": sf_id,
        "FirstName": first,
        "LastName": last,
        "Email": email,
        "Phone": phone,
        "LeadSource": source,
        "Status": status,
        "Company": company,
        "CreatedDate": "2026-05-07T20:00:00.000+0000",
    }


def _make_service(
    sf_records: list[dict[str, Any]] | None = None,
) -> tuple[SfLeadIngestService, MagicMock, MagicMock, MagicMock, MagicMock]:
    """Build SfLeadIngestService with mocked SF + service collaborators."""
    session = MagicMock()
    sf_client = MagicMock()
    sf_client.soql = AsyncMock(
        return_value={"records": sf_records or [], "totalSize": 0, "done": True}
    )

    service = SfLeadIngestService(session=session, sf_client=sf_client)
    # Replace inner services with mocks; keep service._sf as the real mock.
    service._ingest = MagicMock()
    service._ingest.capture = AsyncMock()
    service._identity = MagicMock()
    service._identity._repo = MagicMock()
    service._identity._repo.find_source_link = AsyncMock(return_value=None)
    service._identity.get_person = AsyncMock()
    service._identity.resolve_by_email = AsyncMock(return_value=None)
    service._identity.resolve_by_phone = AsyncMock(return_value=None)
    service._identity.add_source_link = AsyncMock()
    service._identity.resolve_or_create_person = AsyncMock()
    service._ops = MagicMock()
    service._ops.upsert_lead = AsyncMock()
    service._ops.list_recent_sf_leads = AsyncMock(return_value=[])
    return service, service._ingest, service._identity, service._ops, sf_client


def _person(
    *,
    display_name: str = "Jane Doe",
    email: str | None = None,
    phone: str | None = None,
) -> MagicMock:
    p = MagicMock()
    p.id = uuid.uuid4()
    p.display_name = display_name
    p.identifiers = []
    if email:
        ident = MagicMock()
        ident.kind = "email"
        ident.value = email
        p.identifiers.append(ident)
    if phone:
        ident = MagicMock()
        ident.kind = "phone"
        ident.value = phone
        p.identifiers.append(ident)
    return p


def _upsert_result(person_id: Any) -> MagicMock:
    """Mock UpsertLeadResult with .lead.id + .lead.created_at."""
    res = MagicMock()
    res.lead = MagicMock()
    res.lead.id = uuid.uuid4()
    res.lead.created_at = datetime.now(UTC)
    res.was_created = True
    res.was_changed = True
    return res


# --- limit validation ---


@pytest.mark.asyncio
async def test_pull_recent_rejects_limit_zero() -> None:
    service, *_ = _make_service()
    with pytest.raises(ValueError):
        await service.pull_recent(_TENANT_ID, limit=0)


@pytest.mark.asyncio
async def test_pull_recent_rejects_limit_too_high() -> None:
    service, *_ = _make_service()
    with pytest.raises(ValueError):
        await service.pull_recent(_TENANT_ID, limit=51)


# --- pull_recent: brand-new person flow ---


@pytest.mark.asyncio
async def test_pull_recent_brand_new_person_creates_via_resolve_or_create() -> None:
    rec = _record(sf_id="00Q1")
    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    new_person = _person(
        display_name="Jane Doe", email="jane@example.com", phone="+15551234567"
    )
    resolve_result = MagicMock()
    resolve_result.person = new_person
    resolve_result.was_created = True
    identity.resolve_or_create_person.return_value = resolve_result
    ops.upsert_lead.return_value = _upsert_result(new_person.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

    assert len(out) == 1
    assert out[0].sf_lead_id == "00Q1"
    assert out[0].is_reactivation is False
    assert out[0].email == "jane@example.com"

    # Capture happened before resolution.
    ingest.capture.assert_awaited_once()
    capture_call = ingest.capture.await_args
    assert capture_call.args[0] == _TENANT_ID  # tenant forwarded
    # Source-link lookup tried first.
    identity._repo.find_source_link.assert_awaited_once_with(
        _TENANT_ID, "salesforce", "lead", "00Q1"
    )
    # Both reactivation lookups happened (email then phone, both miss),
    # then fell through to resolve_or_create_person.
    identity.resolve_by_email.assert_awaited_once_with(
        _TENANT_ID, "jane@example.com"
    )
    identity.resolve_by_phone.assert_awaited_once_with(
        _TENANT_ID, "+15551234567"
    )
    identity.resolve_or_create_person.assert_awaited_once()
    # Upsert carries provider_metadata.
    upsert_call = ops.upsert_lead.await_args
    assert upsert_call.args[0] == _TENANT_ID
    assert upsert_call.kwargs["person_uid"] == new_person.id
    assert upsert_call.kwargs["provider_metadata"]["sf_lead_id"] == "00Q1"
    assert upsert_call.kwargs["provider_metadata"]["is_reactivation"] is False


# --- pull_recent: re-pull (same source_link) ---


@pytest.mark.asyncio
async def test_pull_recent_repull_reuses_person_no_dedupe_lookup() -> None:
    rec = _record(sf_id="00Q2")
    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    existing_link = MagicMock()
    existing_link.person_uid = uuid.uuid4()
    identity._repo.find_source_link.return_value = existing_link
    same_person = _person(email="jane@example.com")
    same_person.id = existing_link.person_uid
    identity.get_person.return_value = same_person
    ops.upsert_lead.return_value = _upsert_result(same_person.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

    assert len(out) == 1
    assert out[0].is_reactivation is False  # re-pull is NOT reactivation
    # Did NOT consult email/phone resolvers (we already had the source_link).
    identity.resolve_by_email.assert_not_called()
    identity.resolve_by_phone.assert_not_called()
    identity.resolve_or_create_person.assert_not_called()


# --- pull_recent: email reactivation ---


@pytest.mark.asyncio
async def test_pull_recent_email_match_marks_reactivation_and_adds_source_link() -> None:
    rec = _record(sf_id="00Q3", email="jane@example.com")
    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    matched_person = _person(email="jane@example.com", phone="+15551234567")
    identity.resolve_by_email.return_value = matched_person
    ops.upsert_lead.return_value = _upsert_result(matched_person.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

    assert out[0].is_reactivation is True
    identity.add_source_link.assert_awaited_once_with(
        _TENANT_ID, matched_person.id, "salesforce", "lead", "00Q3"
    )
    identity.resolve_by_phone.assert_not_called()  # email already resolved
    identity.resolve_or_create_person.assert_not_called()
    upsert_meta = ops.upsert_lead.await_args.kwargs["provider_metadata"]
    assert upsert_meta["is_reactivation"] is True


# --- pull_recent: phone reactivation (no email match) ---


@pytest.mark.asyncio
async def test_pull_recent_phone_match_when_no_email_match() -> None:
    rec = _record(sf_id="00Q4", email="new@example.com", phone="+15551234567")
    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    identity.resolve_by_email.return_value = None  # email miss
    matched = _person(phone="+15551234567")
    identity.resolve_by_phone.return_value = matched
    ops.upsert_lead.return_value = _upsert_result(matched.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

    assert out[0].is_reactivation is True
    identity.add_source_link.assert_awaited_once_with(
        _TENANT_ID, matched.id, "salesforce", "lead", "00Q4"
    )
    identity.resolve_or_create_person.assert_not_called()


# --- pull_recent: both email and phone empty ---


@pytest.mark.asyncio
async def test_pull_recent_no_email_no_phone_creates_new_person() -> None:
    rec = _record(sf_id="00Q5", email=None, phone=None)
    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    new_person = _person()
    resolve_result = MagicMock()
    resolve_result.person = new_person
    resolve_result.was_created = True
    identity.resolve_or_create_person.return_value = resolve_result
    ops.upsert_lead.return_value = _upsert_result(new_person.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

    assert out[0].is_reactivation is False
    identity.resolve_by_email.assert_not_called()
    identity.resolve_by_phone.assert_not_called()
    identity.resolve_or_create_person.assert_awaited_once()


# --- pull_recent: SOQL invocation shape ---


@pytest.mark.asyncio
async def test_pull_recent_invokes_soql_with_limit() -> None:
    service, ingest, identity, ops, sf = _make_service(sf_records=[])
    await service.pull_recent(_TENANT_ID, limit=7)
    sf.soql.assert_awaited_once()
    query = sf.soql.await_args.args[0]
    assert "LIMIT 7" in query
    assert "FROM Lead" in query
    assert "ORDER BY CreatedDate DESC" in query


# --- list_recent ---


@pytest.mark.asyncio
async def test_list_recent_maps_lead_extra_to_dto() -> None:
    service, ingest, identity, ops, sf = _make_service()

    lead = MagicMock()
    lead.id = uuid.uuid4()
    lead.person_uid = uuid.uuid4()
    lead.created_at = datetime.now(UTC)
    lead.extra = {
        "sf_lead_id": "00Q9",
