-    *,
-    sf_id: str = "00Q123",
-    first: str | None = "Jane",
-    last: str | None = "Doe",
-    email: str | None = "jane@example.com",
-    phone: str | None = "+15551234567",
-    status: str = "Open",
-    source: str = "Web",
-    company: str | None = "Acme",
-) -> dict[str, Any]:
-    return {
-        "Id": sf_id,
-        "FirstName": first,
-        "LastName": last,
-        "Email": email,
-        "Phone": phone,
-        "LeadSource": source,
-        "Status": status,
-        "Company": company,
-        "CreatedDate": "2026-05-07T20:00:00.000+0000",
-    }
-
