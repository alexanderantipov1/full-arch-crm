    service, ingest, identity, ops, sf = _make_service(sf_records=[rec])

    identity.resolve_by_email.return_value = None  # email miss
    matched = _person(phone="+15551234567")
    identity.resolve_by_phone.return_value = matched
    ops.upsert_lead.return_value = _upsert_result(matched.id)

    out = await service.pull_recent(_TENANT_ID, limit=1)

