# ============================================================
# Fusion CRM — Environment configuration (example)
# Copy to `.env` and adjust per environment.
# Never commit `.env` files containing real secrets.
# ============================================================

# --- App ---
APP_ENV=development               # development | production
APP_NAME=fusion-crm
LOG_LEVEL=INFO
SECRET_KEY=change-me-please-generate-a-long-random-value

# --- Database ---
# Async driver for FastAPI/SQLAlchemy 2.0
DATABASE_URL=postgresql+asyncpg://fusion:fusion@postgres:5432/fusion
# Sync URL is used by Alembic (migrations) and the backup script
DATABASE_URL_SYNC=postgresql+psycopg://fusion:fusion@postgres:5432/fusion

POSTGRES_USER=fusion
POSTGRES_PASSWORD=fusion
POSTGRES_DB=fusion

# --- Redis (jobs / queue) ---
REDIS_URL=redis://redis:6379/0

# --- Backups (Google Cloud Storage) ---
GCS_BUCKET=fusion-crm-backups-example
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
BACKUP_RETENTION_DAYS=30
BACKUP_LOCAL_DIR=/var/backups/fusion

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Worker ---
WORKER_CONCURRENCY=4

# --- Tenant resolution (Phase 1 single-tenant) ---
# Slug looked up at request-time to resolve `Principal.tenant_id`.
# Must match a row in `tenant.tenant.slug` (the bootstrap migration
# inserts `fusion-dental-implants`).
TENANT_DEFAULT_SLUG=fusion-dental-implants

# --- Encryption ---
# Fernet key used by EncryptedString columns + the encrypted JSONB
# payload on tenant.integration_credential (ENG-125).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Internal credential resolver (ENG-125) ---
# Shared secret between the Next.js server-side route handlers and the
# FastAPI ``/_internal/credentials/...`` endpoint. The Next.js SF / CS
# clients fetch decrypted credentials from FastAPI using this token.
# Same value MUST be set on the Next.js side as INTERNAL_CREDENTIAL_TOKEN
# (server-only env, never in the public bundle).
#
# ENG-131: this same token is reused as the HMAC key for the OAuth
# ``state`` parameter in the Google Workspace + Microsoft 365 connect
# flow. Without it set, the OAuth start endpoint returns 503.
#
# ENG-134: also keys the open-tracking + one-click-unsubscribe HMAC
# tokens embedded in outbound mail (namespaced by ``"open:"`` /
# ``"unsubscribe:"``).
#
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_CREDENTIAL_TOKEN=

# ============================================================
# Bootstrap-only credentials (ENG-125)
# After the ``tenant_credentials_seed`` migration runs, the SF / CareStack
# values below are copied into ``tenant.integration_credential`` (encrypted
# at rest) and runtime callers read from the DB resolver — env is a
# fallback only. Rotate via ``IntegrationCredentialService.upsert``;
# clearing these keys after the first migration run is safe.
# ============================================================

# --- Salesforce (M1 — Lead pull) ---
# Bootstrap-only: copied to tenant.integration_credential by the
# ``tenant_credentials_seed`` migration. Runtime reads from DB.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_CALLBACK_URL=https://localhost:8000/integrations/salesforce/callback
SALESFORCE_DOMAIN=login.salesforce.com
# Phase 1 dev only — override path to the Salesforce token file. Defaults to
# apps/web/.sf-tokens.json relative to repo root. Leave blank in production.
SF_DEV_TOKEN_FILE=

# --- CareStack (M1 — non-PHI conversion-funnel metadata only) ---
# Bootstrap-only: copied to tenant.integration_credential by the
# ``tenant_credentials_seed`` migration. Runtime reads from DB.
CARESTACK_IDP_BASE_URL=
CARESTACK_API_BASE_URL=
CARESTACK_API_VERSION=v1.0
CARESTACK_CLIENT_ID=
CARESTACK_CLIENT_SECRET=
CARESTACK_VENDOR_KEY=
CARESTACK_ACCOUNT_KEY=
CARESTACK_ACCOUNT_ID=

# ============================================================
# Operator-account email outreach OAuth (ENG-131 / ADR-0004)
# Google Workspace + Microsoft 365 — used to send mail FROM the
# clinic's own mailbox via OAuth (gmail.send / Mail.Send). Tokens
# land in tenant.integration_credential (encrypted, multi-mailbox).
# Personal @gmail.com / @outlook.com accounts are blocked at the
# OAuth callback (HIPAA compliance gate, see ADR-0004 §"HIPAA
# compliance gate" + ENG-131 issue).
# ============================================================

# --- Google Workspace OAuth ---
# Provision via Google Cloud Console:
#   1. APIs & Services → Library → enable "Gmail API".
#   2. APIs & Services → Credentials → Create credentials → OAuth client ID.
#      Application type: Web application. Authorised redirect URIs:
#      <OAUTH_REDIRECT_BASE_URL>/integrations/google_workspace/callback.
#   3. APIs & Services → OAuth consent screen → External, add the
#      sensitive scopes (gmail.send, userinfo.email). Move to
#      "Production" once connected to a Workspace org with a BAA.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Microsoft 365 OAuth ---
# Provision via Azure AD → App registrations:
#   1. New registration. Supported account types:
#      "Accounts in any organisational directory (Multitenant)".
#      (Personal MSAs are blocked downstream by our compliance gate.)
#   2. Redirect URI (Web):
#      <OAUTH_REDIRECT_BASE_URL>/integrations/microsoft_365/callback.
#   3. Certificates & secrets → New client secret → copy the VALUE
#      (not the secret id) into MICROSOFT_OAUTH_CLIENT_SECRET.
#   4. API permissions → Microsoft Graph → Delegated:
#      Mail.Send, User.Read, offline_access, openid, email, profile.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Base URL operators are redirected back to after consent. Both providers
# share the same base. Dev: http://127.0.0.1:8001. Prod: a real HTTPS host
# matching the redirect URIs registered with each OAuth client.
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8001

# ============================================================
# Outreach tracking (ENG-134 / ADR-0004 §"Tracking")
# Base URL the tracking pixel + one-click unsubscribe links resolve
# to. Embedded in every outbound email at send time. MUST be HTTPS
# in production. When unset we fall back to OAUTH_REDIRECT_BASE_URL.
# ============================================================
TRACKING_BASE_URL=

# --- Web frontend ---
# Origin(s) of the staff dashboard SPA. Comma-separated.
WEB_CORS_ORIGINS=http://localhost:5173

# --- Messenger notifications (ENG-455 dedupe core) ---
# Master enablement gate for the messenger rule->outbox engine
# (NotificationEventService.emit). Default OFF so the dedupe + enablement
# wiring lands DARK; flip to true to start sending (prod rollout deferred).
# When false, emit enqueues nothing regardless of rules / dedupe key / cutoff.
NOTIFICATIONS_ENABLED=false
# Historical-entity cutoff (ISO-8601). Only entities whose source_created_at
# is at or after this instant may notify; older entities (e.g. SF/CareStack
# backfills of pre-existing leads) are suppressed even when enabled. Leave
# unset for no cutoff (rely on the enablement flag + per-entity dedupe key).
# Use a timezone-aware value, e.g. 2026-06-15T00:00:00+00:00.
# NOTIFICATIONS_CUTOFF_AT=
# ENG-460: treat the corporate messenger as an AUTHORIZED PHI surface. When
# true, notification cards carry the patient's REAL name / phone / provider
# (renderer runs in phi_mode="full", bypassing the de-identification
# allowlist); when false, cards are de-identified (person_uid + link only).
# Default true per the operator decision (ADR-0006). SECURITY: with this on,
# PHI lands in the Mattermost store, so the Mattermost server must be treated
# as a PHI system (access control / TLS / encrypted backup / retention).
MESSENGER_PHI_FULL=true
