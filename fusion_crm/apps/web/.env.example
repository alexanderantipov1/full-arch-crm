# apps/web — only NEXT_PUBLIC_* values land in the browser bundle.
# Secrets (OAuth client_secret, JWT keys, API keys) live ONLY on the API side.

# Where the FastAPI backend listens.
# In dev: http://localhost:8000. In docker compose: http://api:8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Toggles MSW in the browser. "enabled" → mocks intercept fetch.
# Set to "disabled" once the real API is wired through.
NEXT_PUBLIC_API_MOCKING=enabled

# Mirrors Pydantic Settings.environment so /dev/* pages can self-gate.
# Allowed: local | development | staging | production
NEXT_PUBLIC_ENVIRONMENT=local

# When "true", Salesforce + persons endpoints bypass MSW and hit the real
# Next.js route handlers under app/api/* — which talk to live Salesforce
# using credentials read from the repo-root .env. Keep "false" for the
# pure mock experience.
NEXT_PUBLIC_USE_REAL_SF=false

# --- Server-only credential resolver (ENG-125) ---
# Server-only — NEVER prefixed NEXT_PUBLIC_* (would leak to the bundle).
# Same value as INTERNAL_CREDENTIAL_TOKEN in the repo-root .env. The
# Next.js server-side route handlers use this when they call the FastAPI
# /_internal/credentials/... endpoint to fetch decrypted SF / CareStack
# credentials. Falls back to env-based credentials when unset / 404.
INTERNAL_CREDENTIAL_TOKEN=

# Optional override for the FastAPI base URL the resolver hits (defaults
# to NEXT_PUBLIC_API_BASE_URL or http://localhost:8000). Useful when the
# Next.js process and the API live on different network paths.
INTERNAL_API_BASE_URL=
