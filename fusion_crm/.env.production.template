# ============================================================
# Fusion CRM — Production environment template
# ============================================================
#
# Per ADR-0001 (docs/decisions/ADR-0001-cloud-sql-prod-postgres.md).
#
# Copy to `.env.production` on the deployment host and fill in.
# NEVER commit `.env.production`.
#
# Two ways secrets get materialised:
#
# 1. `gcp-secret://<project>/<name>[/<version>]` URLs — resolved
#    at app startup by packages/core/secrets.py. Used for any
#    field whose VALUE is the entire secret (SECRET_KEY,
#    ENCRYPTION_KEY, *_CLIENT_SECRET, *_VENDOR_KEY, *_ACCOUNT_KEY).
#
# 2. Plain ${DB_PASSWORD} interpolation — the DSN fields cannot
#    embed a gcp-secret URL inside the userinfo portion (the
#    resolver matches whole values, not fragments). For these,
#    fetch the secret into env before docker compose starts:
#
#       DB_PASSWORD=$(gcloud secrets versions access latest \
#         --secret=db-password --project=fusioncrm-494201)
#       export DB_PASSWORD
#       docker compose -f infra/docker/docker-compose.prod.yml \
#         --env-file .env.production up -d
#
#    A wrapper at `infra/scripts/start_prod.sh` does this for you.

# --- Compose-time settings (plain values) -------------------------

CLOUDSQL_INSTANCE_CONNECTION_NAME=fusioncrm-494201:us-west1:fusion-crm-pg

# Host path to the runtime SA-key JSON used by api/worker.
# Use a dedicated runtime SA (e.g. fusion-api-sa). NOT the migrator SA.
GCP_SA_KEY_HOST_PATH=/etc/fusion/secrets/gcp-sa.json

API_PORT=8000
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO

# --- App ----------------------------------------------------------

APP_ENV=production
APP_NAME=fusion-crm

SECRET_KEY=gcp-secret://fusioncrm-494201/app-secret-key/latest

# --- Tenant resolution (Phase 1 single-tenant) --------------------
#
# Slug resolved to `tenant.tenant.id` at request time. Must match the
# bootstrap row inserted by the `tenant_bootstrap_seed` Alembic
# migration. Phase 2 (real multi-tenant) introduces a subdomain /
# path resolver and this becomes a fallback for workers and CLI.

TENANT_DEFAULT_SLUG=fusion-dental-implants

# --- Database (via Cloud SQL Auth Proxy alias `postgres`) ---------
#
# DB_PASSWORD must be exported BEFORE invoking docker compose.
# See infra/scripts/start_prod.sh for the full wrapper.

DATABASE_URL=postgresql+asyncpg://fusion:${DB_PASSWORD}@postgres:5432/fusion
DATABASE_URL_SYNC=postgresql+psycopg://fusion:${DB_PASSWORD}@postgres:5432/fusion

# --- Redis (local container in prod compose for now) --------------

REDIS_URL=redis://redis:6379/0

# --- Backups (Cloud SQL PITR primary; backup.sh secondary) --------

GCS_BUCKET=fusion-crm-backups
BACKUP_RETENTION_DAYS=90
BACKUP_LOCAL_DIR=/var/backups/fusion

# --- API / Web CORS -----------------------------------------------

API_CORS_ORIGINS=["https://app.fusioncrm.example"]
WEB_CORS_ORIGINS=https://app.fusioncrm.example

# --- Encryption key for `integrations.*` token columns ------------

ENCRYPTION_KEY=gcp-secret://fusioncrm-494201/encryption-key/latest

# --- Salesforce (Connected App OAuth) -----------------------------

SALESFORCE_CLIENT_ID=<paste plain client id from SF connected app>
SALESFORCE_CLIENT_SECRET=gcp-secret://fusioncrm-494201/salesforce-client-secret/latest
SALESFORCE_CALLBACK_URL=https://app.fusioncrm.example/api/integrations/salesforce/callback
SALESFORCE_DOMAIN=

# --- CareStack ----------------------------------------------------

CARESTACK_IDP_BASE_URL=https://id.carestack.com
CARESTACK_API_BASE_URL=https://antipov.carestack.com
CARESTACK_API_VERSION=v1.0
CARESTACK_CLIENT_ID=<paste plain client id>
CARESTACK_CLIENT_SECRET=gcp-secret://fusioncrm-494201/carestack-client-secret/latest
CARESTACK_VENDOR_KEY=gcp-secret://fusioncrm-494201/carestack-vendor-key/latest
CARESTACK_ACCOUNT_KEY=gcp-secret://fusioncrm-494201/carestack-account-key/latest
CARESTACK_ACCOUNT_ID=10762
