# Example env file for the production Mattermost host (ENG-494 / Block I).
#
# The REAL file lives ONLY on the VM at /opt/mattermost/mattermost.env, chmod 600,
# owned by the operator. It is NEVER committed to the repo (DEPLOYMENT_RULES §6).
# Secret values are resolved from Secret Manager on the VM and written into that
# file by hand; this .example carries placeholders only.
#
# Used by:
#   docker compose -f docker-compose.yml --env-file mattermost.env up -d

# --- Database (dedicated Cloud SQL fusion-mm-pg, reached over its private IP) ---
# MM_DB_HOST is the PRIVATE IP printed by provision_mattermost_cloudsql.sh.
MM_DB_HOST=10.10.0.X
MM_DB_USER=mmuser
MM_DB_NAME=mattermost
# SECRET — from: gcloud secrets versions access latest --secret=mattermost-db-password
MM_DB_PASSWORD=__FROM_SECRET_MANAGER__

# --- Public site + proxy ---------------------------------------------------------
# No localhost / no http:// in any prod URL (DEPLOYMENT_RULES §4).
MM_SITE_URL=https://chat.fusioncrm.app
MM_SITE_DOMAIN=chat.fusioncrm.app
ACME_EMAIL=eduard@drantipov.com

# --- Outgoing-webhook target allowlist (public Fusion API host) ------------------
MM_ALLOWED_INTERNAL=fusioncrm.app

# --- File store: GCS via S3-compatible endpoint ----------------------------------
# Default driver is amazons3 (GCS S3-compat). To fall back to local-disk filestore,
# set MM_FILESTORE_DRIVER=local, add a persistent disk for /mattermost/data, and
# wire a GCS backup cron (see README "Design decisions").
MM_FILESTORE_DRIVER=amazons3
MM_GCS_BUCKET=fusion-crm-mattermost
MM_GCS_ENDPOINT=storage.googleapis.com
MM_GCS_REGION=us-west1
# SECRETS — GCS HMAC interoperability keys (S3 driver auth; the VM SA is NOT used
# for object auth by the S3 driver). Generate once at smoke time:
#   gcloud storage hmac keys create --service-account=fusion-mm-vm-sa@fusioncrm-494201.iam.gserviceaccount.com
# then store both halves in Secret Manager and copy them here:
#   mattermost-gcs-hmac-access  / mattermost-gcs-hmac-secret
MM_GCS_HMAC_ACCESS_KEY=__FROM_SECRET_MANAGER__
MM_GCS_HMAC_SECRET_KEY=__FROM_SECRET_MANAGER__
